# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3333
API_VERSION=v1

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=betforge
DB_PASS=betforge_secret
DB_NAME=betforge_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=betforge_dev_secret_32chars_minimum_ok!
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=betforge_dev_refresh_secret_32chars!
JWT_REFRESH_EXPIRES_IN=30d

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Odds API ─────────────────────────────────────────────────────────────────
ODDS_API_KEY=
ODDS_CACHE_TTL_SECONDS=60

# ─── PlayFiver (Cassino) ───────────────────────────────────────────────────────
# Chave de API (fornecida pela PlayFiver no painel: https://www.playfiver.app)
PLAYFIVER_API_KEY=

# URL base da API (não alterar)
PLAYFIVER_BASE_URL=https://api.playfivers.com

# ID do operador (fornecido pela PlayFiver)
PLAYFIVER_OPERATOR_ID=

# URL pública que a PlayFiver chamará para debit/credit/rollback (ngrok em dev)
# Exemplo: https://meu-site.com/api/v1/casino/callback
PLAYFIVER_CALLBACK_URL=

# URL para redirecionar o jogador ao fechar o jogo (opcional)
PLAYFIVER_RETURN_URL=

# Segredo HMAC-SHA256 para validar assinatura dos callbacks
PLAYFIVER_WEBHOOK_SECRET=

# ─── Mercado Pago ──────────────────────────────────────────────────────────────
# Access Token (TEST-... para sandbox, APP_USR-... para producao)
# Dashboard: https://www.mercadopago.com.br/developers/panel/app
MP_ACCESS_TOKEN=TEST-TROQUE_PELO_SEU_ACCESS_TOKEN

# URL base da API (nao mudar)
MP_BASE_URL=https://api.mercadopago.com

# URL publica que o MP vai chamar para notificacoes (use ngrok em dev)
# Exemplo: https://seu-ngrok.ngrok.io/api/v1/webhooks/mercadopago
MP_WEBHOOK_URL=

# Segredo para validacao de assinatura dos webhooks
# Dashboard > Suas integracoes > Webhooks > Chave secreta
MP_WEBHOOK_SECRET=
