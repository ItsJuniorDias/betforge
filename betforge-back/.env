# ─── Servidor ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3333
API_VERSION=v1

# ─── Banco de Dados (mesmos valores do docker-compose.yml) ───────
DB_HOST=localhost
DB_PORT=5432
DB_USER=betforge
DB_PASS=betforge_secret
DB_NAME=betforge_db
DB_POOL_MIN=2
DB_POOL_MAX=10

DATABASE_URL=postgresql://betforge:betforge_secret@localhost:5432/betforge_db

# ─── Redis ───────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT (troque em produção!) ───────────────────────────────────
JWT_SECRET=1644be60a3ff4193a1b06a6183cb56ae7b8072567adf6b5bc94406c197b859eab28a49e3caf1bc50034c61a8d42d73527eb80e7be6a94239844b58cea0edefaf
